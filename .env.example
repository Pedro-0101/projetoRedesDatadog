# Datadog — copie para .env e preencha
DD_API_KEY=
# DD_APP_KEY é necessário para criar dashboards/SLOs/monitors via API (Etapa 5)
# e para a auto-remediação (poll do estado dos monitors).
DD_APP_KEY=
DD_SITE=us5.datadoghq.com
# URL do dashboard criado por scripts/datadog-setup.sh (aparece como botão na UI)
DD_DASHBOARD_URL=
# Closed-loop: quando true, a API consulta os monitors demo:sdn e bloqueia/reativa
# workers automaticamente conforme eles entram em Alert/OK. Requer DD_API_KEY+DD_APP_KEY.
SDN_AUTOREMEDIATION=false
